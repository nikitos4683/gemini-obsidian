{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "obsidian_(create|append)_note|obsidian_update_frontmatter",
        "hooks": [
          {
            "name": "obsidian-reindex",
            "type": "command",
            "command": "node ${extensionPath}/dist/index.js obsidian_rag_index --file_path \"${toolInput.file_path}\"",
            "description": "Re-indexes only the changed note after it is created or modified."
          }
        ]
      }
    ]
  }
}
