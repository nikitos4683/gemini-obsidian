[0.023, "o", "\u001b[?2026h\u001b[1;1H\u001b[24B\u001b[38;2;110;106;134m│\u001b[39m \u001b[2m---\u001b[22m                                                                                                                                                                                                                               \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m▄\u001b[39m\r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[2m---\u001b[22m                                                                                                                                                                                                                               \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[19B   \u001b[38;2;224;222;244m* \u001b[1mConsistent Voice:\u001b[22m Reducing the cognitive load of switching between different styles or behavioral constraints.\u001b[39m                                                                                                                   \r\n                                                                                                                 "]
