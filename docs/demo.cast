[0.000, "o", "                                                                                                                                                             \u001b[38;2;69;71;90m█\u001b[39m\r\n                                                                                                                                                                                                                                     \u001b[38;2;69;71;90m█\u001b[39m\r\n  \u001b[1m\u001b[38;2;224;222;244m1. The New Productivity Bottleneck: Information Discovery\u001b[39m\u001b[22m                                                                                                                                                                          \u001b[38;2;69;71;90m█\u001b[39m\r\n  \u001b[38;2;224;222;244mThe primary source of friction for engineering teams has shifted. While technical debt was once the top concern, the \u001b[1mAtlassian State of Developer Experience 2025\u001b[22m report indicates that \u001b[1mfinding information\u001b[22m is now the #1 \"time\u001b[39m    \u001b[38;2;69;71;90m█\u001b[39m\r\n "]
[0.000, "o", " \u001b[38;2;224;222;244msuck.\"\u001b[39m                                                                                                                                                                                                                             \u001b[38;2;69;71;90m█\u001b[39m\r\n   \u001b[38;2;224;222;244m*\u001b[39m \u001b[1m\u001b[38;2;224;222;244mArticle Angle:\u001b[22m Coding agents aren't just for writing functions; their greatest productivity impact may be as intelligent retrieval layers that solve the information discovery problem, allowing developers to bypass the\u001b[39m       \u001b[38;2;69;71;90m█\u001b[39m\r\n     \u001b[38;2;224;222;244mfriction of navigating fragmented documentation and legacy codebases.\u001b[39m                                                                                                                                                           \u001b[38;2;69;71;90m█\u001b[39m\r\n                                                                                                                                                           "]
[0.000, "o", "                                                                          \u001b[38;2;69;71;90m█\u001b[39m\r\n                                                                                                                                                                                                                                     \u001b[38;2;69;71;90m█\u001b[39m\r\n  \u001b[1m\u001b[38;2;224;222;244m2. Agents as Standardization Engines\u001b[39m\u001b[22m                                                                                                                                                                                               \u001b[38;2;69;71;90m█\u001b[39m\r\n  \u001b[38;2;224;222;244mYour notes on \"core concepts\" highlight that agents provide:\u001b[39m                                                                                                                                                                       \u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[9B\u001b[52;4H\u001b[?2026l"]
[0.024, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠴\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 14s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
[0.081, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠦\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 14s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
[0.087, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠧\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 14s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
[0.084, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠇\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 14s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
[0.079, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠏\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 14s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
[0.069, "o", "\u001b[?2026h\u001b[1;1H\u001b[24B\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mthey can also apply in the domain layer.\u001b[39m                                                                                                                                                                                       \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m▄\u001b[39m\r\n\u001b[20B  \u001b[38;2;224;222;244mYour notes on \"core concepts\" highlight that agents provide:\u001b[39m                                                                                                                                                                       \u001b[38;2;69;71;90m▀\u001b[39m\r\n   \u001b[38;2;224;222;244m* \u001b[1mDomain Expertise:\u001b[22m Specialized agents (Go, Security, DevOps) provide deep knowledge on demand.\u001b[39m                                                                                                                                    \r\n\u001b[8B\u001b[52;4H\u001b[?2026l"]
[0.045, "o", "\u001b[?2026h\u001b[1;1H\u001b[3B\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mknowledge-rich model and distill it.\u001b[39m                                                                                                                                                                                           \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m      \u001b[38;2;224;222;244m- Note: One thing that I need to improve upon is these types of brainstorming sessions. This also comes down to my lack of ability to focus in most meetings.,\u001b[39m                                                               \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] Highly productive teams grow their knowledge consciously, practicing continuous learning (Kerievsky 2003). For developers, this means improving technical knowledge, along with general domain-modeling skills\u001b[39m  \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244m(such as those in this book). Bu"]
[0.000, "o", "t it also includes serious learning about the specific domain they are working in.\u001b[39m                                                                                                             \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m      \u001b[38;2;224;222;244m- Note: Highly productive teams also practice DevOps. How do I become interested enough in the business to want to become intimate with the domain?\u001b[39m                                                                          \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] Policy is another name for the design pattern known as STRATEGY (Gamma et al. 1995). It is usually motivated by the need to substitute different rules, which is not needed here, as far as we know.\u001b[39m            \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] A domain model can be the core of a common language for a software project. The model is a set of concepts built up i"]
[0.000, "o", "n the heads of people on the project, with terms and relationships that reflect domain\u001b[39m     \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244minsight. These terms and interrelationships provide the semantics of a language that is tailored to the domain while being precise enough for technical development. This is a crucial cord that weaves the model into\u001b[39m         \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mdevelopment activity and binds it with the code.\u001b[39m                                                                                                                                                                               \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] The Language Instinct, by Steven Pinker\u001b[39m                                                                                                                                                                         \u001b[38"]
[0.000, "o", ";2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] If sophisticated domain experts don’t understand the model, there is something wrong with the model.\u001b[39m                                                                                                            \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] The essential principle is that any element of a layer depends only on other elements in the same layer or on elements of the layers “beneath” it. Communication upward must pass through some indirect\u001b[39m         \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mmechanism,\u001b[39m                                                                                                                                                                                                                     \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m-\u001b[39m \u001b[38;2;224;22"]
[0.000, "o", "2;244m[[2021-08-03]] An object defined primarily by its identity is called an ENTITY.1 ENTITIES have special modeling and design considerations. They have life cycles that can radically change their form and content, but a\u001b[39m       \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mthread of continuity must be maintained.\u001b[39m                                                                                                                                                                                       \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m-\u001b[39m \u001b[38;2;224;222;244m[[2021-08-03]] An object that represents a descriptive aspect of the domain with no conceptual identity is called a VALUE OBJECT. VALUE OBJECTS are instantiated to represent elements of the design that we care about only\u001b[39m   \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mfor what they are, not who or which they are.\u001b[39m                    "]
[0.000, "o", "                                                                                                                                                              \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m-\u001b[39m \u001b[38;2;224;222;244m[[2021-08-03]] A SERVICE is an operation offered as an interface that stands alone in the model, without encapsulating state, as ENTITIES and VALUE OBJECTS do. SERVICES are a common pattern in technical frameworks, but\u001b[39m     \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mthey can also apply in the domain layer.\u001b[39m                                                                                                                                                                                       \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m  \u001b[38;2;224;222;244m- [[2021-08-03]] A good SERVICE has three characteristics. 1. The operation relates to a domain concept that is not a natural part of an ENTITY or V"]
[0.000, "o", "ALUE OBJECT. 2. The interface is defined in terms of other elements of the\u001b[39m   \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m    \u001b[38;2;224;222;244mdomain model. 3. The operation is stateless.\u001b[39m                                                                                                                                                                                   \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[2m---\u001b[22m                                                                                                                                                                                                                               \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[2m---\u001b[22m                                                                                                                                                                                                                               \u001b[38;2;110;106;134m│\u001b[39m \r\n\u001b[38;2;110;106;134"]
[0.000, "o", "m│\u001b[39m \u001b[38;2;224;222;244mFile: working/idx_team/Reading List.md\u001b[39m                                                                                                                                                                                            \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[38;2;224;222;244mRelevance: 1.2762482166290283\u001b[39m                                                                                                                                                                                                     \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[38;2;224;222;244mContent: - \u001b[3mThe Why:\u001b[23m The science of delivery. It provides the evidence for which metrics (DORA) actually move the needle for developer velocity.\u001b[39m                                                                                   \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[38;2;110;106;134m│\u001b[39m \u001b[2m---\u001b[22m               "]
[0.000, "o", "                                                                                                                                                                                                                \u001b[38;2;110;106;134m│\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[38;2;110;106;134m╰───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╯\u001b[38;2;69;71;90m█\u001b[39m\r\n\u001b[38;2;196;167;231m✦ \u001b[38;2;224;22"]
[0.000, "o", "2;244mBased on your notes, here is a synthesized framework for your article on developer productivity in the age of LLMs and coding agents:\u001b[39m                                                                                              \u001b[38;2;69;71;90m█\u001b[39m\r\n                                                                                                                                                                                                                                     \u001b[38;2;69;71;90m█\u001b[39m\r\n                                                                                                                                                                                                                                     \u001b[38;2;69;71;90m█\u001b[39m\r\n  \u001b[1m\u001b[38;2;224;222;244m1. The New Productivity Bottleneck: Information Discovery\u001b[39m\u001b[22m                                                                                                                                                              "]
