[0.081, "o", "\u001b[?2026h\u001b[1;1H\u001b[47B\u001b[38;2;224;222;244m⠼\u001b[39m \u001b[38;2;196;167;231mMapping Agent Applications\u001b[39m \u001b[38;2;110;106;134m(esc to cancel, 16s)\u001b[39m                                                                                                                                                                                     \r\n\u001b[7B\u001b[52;4H\u001b[?2026l"]
